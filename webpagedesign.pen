                {
                  "type": "text",
                  "id": "4XRBR",
                  "name": "p1",
                  "fill": "#1E2935",
                  "textGrowth": "fixed-width",
                  "width": 358,
                  "content": "Tens of thousands of space objects require multi-day conjunction screenings. High-fidelity uncertainty propagation is computationally prohibitive, causing false alerts and operator overload.",
